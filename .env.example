#
# Copy this file to .env for local development.
# On the VPS/slash-command deploy path, copy the Sentry deploy values to
# /home/debian/Portfolio/.env.sentry.deploy so redeploy.sh can load them
# without relying on an interactive shell environment. Never commit the real
# auth token.
#
VITE_APP_BASE=/
VITE_BUILD_OUT_DIR=dist
VITE_BUILD_SOURCEMAP=false
VITE_BUILD_CHUNK_WARNING_LIMIT=500
VITE_BUILD_LEGACY_ASSET_DIRS=images,fonts
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=ape-prod-portfolio@1.0.0
SENTRY_ORG=ape-prod
SENTRY_FRONTEND_PROJECT=primaterie-frontend
SENTRY_BACKEND_PROJECT=primaterie-backend
SENTRY_AUTH_TOKEN=
SENTRY_ENABLE_TEST_ENDPOINTS=0
